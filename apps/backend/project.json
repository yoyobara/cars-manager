{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/backend/app",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python run.py",
        "cwd": "apps/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=. ../../.venv/bin/pytest",
        "cwd": "apps/backend"
      }
    }
  }
}
